generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions", "partialIndexes"]
  compilerBuild   = "fast"
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector"), earthdistance(schema: "public"), cube(schema: "public")]
}

// ─── ENUMS ──────────────────────────────────────────────

enum MenuSource {
  website
  google_photos
  ubereats
  doordash
  manual
}

enum PhotoSource {
  google_maps
  yelp
  ubereats
  doordash
  user_submitted
}

enum MacroSource {
  restaurant_published  // Tier 1: from the restaurant's own website/menu
  third_party_db        // Tier 2: from MyFitnessPal, LoseIt, USDA, etc.
  vision_ai             // Tier 3: our own AI estimation pipeline
  usda_match            // Legacy: matched to USDA entry
  community_verified    // Community-verified values
}

// ─── MENU ITEM ENUMS ───────────────────────────────────

enum MenuItemType {
  dish        // mains, appetizers, starters, soups, salads
  dessert     // sweets, pastries, ice cream
  drink       // ALL beverages (basic + special)
  side        // sides, bread, rice
  condiment   // sauces, dressings, dips
  addon       // extras, upgrades, substitutions
  combo       // meal deals, combos, bundles
  kids        // kids menu items
  unknown     // not yet classified
}

enum MenuItemSource {
  website
  google_photos
  delivery_platform
  compliance_page
  manual
  backfill
}

enum ArchiveReason {
  menu_removed
  junk_detected
  duplicate
  manual
}

enum DeliveryPlatform {
  ubereats
  doordash
  grubhub
  seamless
}

enum FeedbackType {
  portion_bigger
  portion_smaller
  portion_accurate
  ingredient_correction
  dish_unavailable
  photo_submission
}

// ─── DISCOVERY ─────────────────────────────────────────

model DiscoveryArea {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   // e.g. "Midtown Manhattan", "Williamsburg"
  latitude              Decimal  @db.Decimal(10, 7)
  longitude             Decimal  @db.Decimal(10, 7)
  radiusMiles           Decimal  @default(0.5) @map("radius_miles") @db.Decimal(4, 1)
  discoveryIntervalDays Int      @default(7) @map("discovery_interval_days")
  priority              Int      @default(3) // 1=high, 5=low
  isActive              Boolean  @default(true) @map("is_active")
  lastDiscoveredAt      DateTime? @map("last_discovered_at")
  restaurantsFoundTotal Int      @default(0) @map("restaurants_found_total")
  restaurantsFoundLast  Int      @default(0) @map("restaurants_found_last") // new restaurants found in last run
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([isActive, priority], map: "idx_discovery_active_priority")
  @@map("discovery_areas")
}

// ─── MODELS ─────────────────────────────────────────────

model Restaurant {
  id                   String   @id @default(uuid()) @db.Uuid
  googlePlaceId        String   @unique @map("google_place_id")
  name                 String
  address              String
  latitude             Decimal  @db.Decimal(10, 7)
  longitude            Decimal  @db.Decimal(10, 7)
  cuisineType          String[] @map("cuisine_type")
  priceLevel           Int?     @map("price_level")
  phone                String?
  websiteUrl           String?  @map("website_url")
  googleRating         Decimal? @map("google_rating") @db.Decimal(2, 1)
  yelpRating           Decimal? @map("yelp_rating") @db.Decimal(2, 1)
  yelpBusinessId       String?  @map("yelp_business_id")
  acceptsReservations  Boolean? @map("accepts_reservations")
  lastMenuCrawl        DateTime? @map("last_menu_crawl")
  lastReviewCrawl      DateTime? @map("last_review_crawl")
  lastTrafficUpdate    DateTime? @map("last_traffic_update")
  lastDeliveryScrape   DateTime? @map("last_delivery_scrape")
  menuSource           MenuSource? @map("menu_source")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  dishes               Dish[]
  menuItems            MenuItem[]
  logistics            RestaurantLogistics[]
  deliveryOptions      RestaurantDelivery[]

  @@map("restaurants")
}

model Dish {
  id                 String      @id @default(uuid()) @db.Uuid
  restaurantId       String      @map("restaurant_id") @db.Uuid
  name               String
  description        String?
  price              Decimal?    @db.Decimal(8, 2)
  category           String?
  ingredientsRaw     String?     @map("ingredients_raw")
  ingredientsParsed  Json?       @map("ingredients_parsed")
  dietaryFlags       Json?       @map("dietary_flags")
  dietaryConfidence  Decimal?    @map("dietary_confidence") @db.Decimal(3, 2)
  caloriesMin        Int?        @map("calories_min")
  caloriesMax        Int?        @map("calories_max")
  proteinMinG        Decimal?    @map("protein_min_g") @db.Decimal(6, 1)
  proteinMaxG        Decimal?    @map("protein_max_g") @db.Decimal(6, 1)
  carbsMinG          Decimal?    @map("carbs_min_g") @db.Decimal(6, 1)
  carbsMaxG          Decimal?    @map("carbs_max_g") @db.Decimal(6, 1)
  fatMinG            Decimal?    @map("fat_min_g") @db.Decimal(6, 1)
  fatMaxG            Decimal?    @map("fat_max_g") @db.Decimal(6, 1)
  macroConfidence    Decimal?    @map("macro_confidence") @db.Decimal(3, 2)
  macroSource        MacroSource? @map("macro_source")
  macroSourceName    String?     @map("macro_source_name")    // e.g. "Panda Express Nutrition Page", "MyFitnessPal"
  macroSourceUrl     String?     @map("macro_source_url")     // URL to the source
  macroSourceLogCount Int?       @map("macro_source_log_count") // For 3rd-party DB: how many users logged this entry
  crossValidated     Boolean     @default(false) @map("cross_validated") // Was AI estimate cross-checked?
  crossValidationSource String?  @map("cross_validation_source") // e.g. "MyFitnessPal generic tofu pad thai"
  crossValidationDeviation Decimal? @map("cross_validation_deviation") @db.Decimal(5, 2) // % deviation from cross-val source
  photoCountAnalyzed Int         @default(0) @map("photo_count_analyzed")
  // macro_embedding handled via raw SQL (pgvector)
  isAvailable        Boolean     @default(true) @map("is_available")
  lastVerified       DateTime?   @map("last_verified")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  restaurant         Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems          MenuItem[]
  photos             DishPhoto[]
  reviewSummary      ReviewSummary?
  communityFeedback  CommunityFeedback[]
  favorites          UserFavorite[]

  @@index([restaurantId], map: "idx_dishes_restaurant")
  @@index([caloriesMin, caloriesMax], map: "idx_dishes_calories")
  @@index([category], map: "idx_dishes_category")
  @@index([isAvailable], map: "idx_dishes_available")
  @@index([macroSource], map: "idx_dishes_macro_source")
  @@map("dishes")
}

model MenuItem {
  id               String          @id @default(uuid()) @db.Uuid
  restaurantId     String          @map("restaurant_id") @db.Uuid
  name             String          // cleaned display name
  nameNormalized   String          @map("name_normalized") // lowercase, stripped — used for dedup
  nameOriginal     String?         @map("name_original") // pre-translation if non-English
  description      String?
  price            Decimal?        @db.Decimal(8, 2)
  category         String?         // menu section (Appetizers, Mains, etc.)
  menuItemType     MenuItemType    @default(unknown) @map("menu_item_type")
  source           MenuItemSource  @default(website)
  photoUrl         String?         @map("photo_url")

  // Scraped from menu (primary source — restaurant-stated, highest trust)
  menuCalories     Int?            @map("menu_calories")
  menuProteinG     Decimal?        @map("menu_protein_g") @db.Decimal(6, 1)
  menuCarbsG       Decimal?        @map("menu_carbs_g") @db.Decimal(6, 1)
  menuFatG         Decimal?        @map("menu_fat_g") @db.Decimal(6, 1)
  menuAllergens    String[]        @default([]) @map("menu_allergens")   // e.g. ["contains peanuts", "dairy"]
  menuDietaryTags  String[]        @default([]) @map("menu_dietary_tags") // e.g. ["V", "GF", "DF"] as printed
  menuIngredients  String?         @map("menu_ingredients")

  // Dish card decision
  isDishCard       Boolean         @default(false) @map("is_dish_card") // Whether this item gets a dish card
  dishCardConfidence Decimal?      @map("dish_card_confidence") @db.Decimal(3, 2) // LLM confidence for dish card decision

  // Audit result
  auditConfidence  Decimal?        @map("audit_confidence") @db.Decimal(3, 2)

  // Soft delete
  archivedAt       DateTime?       @map("archived_at")
  archivedReason   ArchiveReason?  @map("archived_reason")

  // Freshness tracking
  firstSeenAt      DateTime        @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime        @default(now()) @map("last_seen_at")

  // Link to promoted Dish (many MenuItems can point to same Dish)
  dishId           String?         @map("dish_id") @db.Uuid
  dish             Dish?           @relation(fields: [dishId], references: [id], onDelete: SetNull)
  restaurant       Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@unique([restaurantId, nameNormalized, source], map: "uq_menu_item_dedup")
  @@index([restaurantId, archivedAt], map: "idx_menu_items_restaurant_active")
  @@index([restaurantId, menuItemType, archivedAt], map: "idx_menu_items_type_active")
  @@index([dishId], map: "idx_menu_items_dish")
  @@index([restaurantId, lastSeenAt], map: "idx_menu_items_freshness")
  @@index([isDishCard, restaurantId], map: "idx_menu_items_dish_card")
  @@map("menu_items")
}

model DishPhoto {
  id              String      @id @default(uuid()) @db.Uuid
  dishId          String      @map("dish_id") @db.Uuid
  sourceUrl       String      @map("source_url")
  sourcePlatform  PhotoSource @map("source_platform")
  macroEstimate   Json?       @map("macro_estimate")
  volumeEstimateMl Decimal?   @map("volume_estimate_ml") @db.Decimal(8, 1)
  analyzedAt      DateTime?   @map("analyzed_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  dish            Dish        @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("dish_photos")
}

model ReviewSummary {
  id                    String   @id @default(uuid()) @db.Uuid
  dishId                String   @unique @map("dish_id") @db.Uuid
  totalReviewsAnalyzed  Int      @default(0) @map("total_reviews_analyzed")
  googleReviewCount     Int      @default(0) @map("google_review_count")
  yelpReviewCount       Int      @default(0) @map("yelp_review_count")
  averageDishRating     Decimal? @map("average_dish_rating") @db.Decimal(3, 2)
  summaryText           String?  @map("summary_text")
  sentimentPositivePct  Decimal? @map("sentiment_positive_pct") @db.Decimal(5, 2)
  sentimentNegativePct  Decimal? @map("sentiment_negative_pct") @db.Decimal(5, 2)
  commonPraises         String[] @map("common_praises")
  commonComplaints      String[] @map("common_complaints")
  dietaryWarnings       String[] @map("dietary_warnings")
  lastUpdated           DateTime @default(now()) @map("last_updated")

  // Delivery platform dish-level ratings (DoorDash thumbs up/down, Uber Eats liked %)
  doordashThumbsUpPct      Decimal?  @map("doordash_thumbs_up_pct") @db.Decimal(5, 2)
  doordashReviewCount      Int       @default(0) @map("doordash_review_count")
  ubereatsThumbsUpPct      Decimal?  @map("ubereats_thumbs_up_pct") @db.Decimal(5, 2)
  ubereatsReviewCount      Int       @default(0) @map("ubereats_review_count")
  isMostLiked              Boolean   @default(false) @map("is_most_liked")
  lastDeliveryRatingUpdate DateTime? @map("last_delivery_rating_update")

  dish                  Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("review_summaries")
}

model RestaurantLogistics {
  id                  String   @id @default(uuid()) @db.Uuid
  restaurantId        String   @map("restaurant_id") @db.Uuid
  dayOfWeek           Int      @map("day_of_week")
  hour                Int
  typicalBusynessPct  Int?     @map("typical_busyness_pct")
  estimatedWaitMinutes Int?    @map("estimated_wait_minutes")
  updatedAt           DateTime @default(now()) @map("updated_at")

  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek, hour])
  @@map("restaurant_logistics")
}

model RestaurantDelivery {
  id                          String           @id @default(uuid()) @db.Uuid
  restaurantId                String           @map("restaurant_id") @db.Uuid
  platform                    DeliveryPlatform
  isAvailable                 Boolean          @default(true) @map("is_available")
  deliveryFeeMin              Decimal?         @map("delivery_fee_min") @db.Decimal(6, 2)
  deliveryFeeMax              Decimal?         @map("delivery_fee_max") @db.Decimal(6, 2)
  estimatedDeliveryMinutesMin Int?             @map("estimated_delivery_minutes_min")
  estimatedDeliveryMinutesMax Int?             @map("estimated_delivery_minutes_max")
  platformUrl                 String?          @map("platform_url")
  lastChecked                 DateTime         @default(now()) @map("last_checked")

  restaurant                  Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, platform])
  @@map("restaurant_delivery")
}

model UserProfile {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String   @unique
  name                 String
  passwordHash         String?  @map("password_hash")
  dietaryRestrictions  Json?    @map("dietary_restrictions")
  allergenExclusions   String[] @map("allergen_exclusions")
  customRestrictions   String[] @map("custom_restrictions")
  nutritionalGoals     Json?    @map("nutritional_goals")
  maxWaitMinutes       Int      @default(30) @map("max_wait_minutes")
  searchRadiusMiles    Decimal  @default(2.0) @map("search_radius_miles") @db.Decimal(4, 1)
  preferredCuisines    String[] @map("preferred_cuisines")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  communityFeedback        CommunityFeedback[]
  favorites                UserFavorite[]
  notificationPreference   NotificationPreference?
  pushSubscriptions        PushSubscription[]
  notifications            NotificationLog[]

  @@map("user_profiles")
}

model UserFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  dishId    String   @map("dish_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  dish      Dish        @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@map("user_favorites")
}

model CommunityFeedback {
  id           String       @id @default(uuid()) @db.Uuid
  dishId       String       @map("dish_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  feedbackType FeedbackType @map("feedback_type")
  details      Json?
  photoUrl     String?      @map("photo_url")
  createdAt    DateTime     @default(now()) @map("created_at")

  dish         Dish         @relation(fields: [dishId], references: [id], onDelete: Cascade)
  user         UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("community_feedback")
}

// ── Notifications ──────────────────────────────────────

enum NotificationType {
  new_dish_match
  favorite_updated
  wait_time_drop
  weekly_digest
}

enum NotificationChannel {
  in_app
  web_push
}

model NotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  inAppEnabled    Boolean  @default(true) @map("in_app_enabled")
  pushEnabled     Boolean  @default(false) @map("push_enabled")
  newDishMatch    Boolean  @default(true) @map("new_dish_match")
  favoriteUpdated Boolean  @default(true) @map("favorite_updated")
  waitTimeDrop    Boolean  @default(true) @map("wait_time_drop")
  weeklyDigest    Boolean  @default(true) @map("weekly_digest")
  quietHoursStart Int?     @map("quiet_hours_start")
  quietHoursEnd   Int?     @map("quiet_hours_end")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model NotificationLog {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      NotificationType
  channel   NotificationChannel
  title     String
  body      String
  data      Json?
  readAt    DateTime?           @map("read_at")
  clickedAt DateTime?           @map("clicked_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], map: "idx_notifications_user_unread")
  @@index([createdAt], map: "idx_notifications_created")
  @@map("notification_log")
}

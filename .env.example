# Database
# Use port 5432 with Docker Compose, or 5433 if running Homebrew PG alongside existing PG
DATABASE_URL=postgresql://nutriscout:nutriscout_dev@localhost:5432/nutriscout

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (Claude API for vision analysis & review summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API (restaurant discovery, photos, popular times)
GOOGLE_PLACES_API_KEY=...

# BestTime.app API (foot traffic / busyness data)
BESTTIME_API_KEY=...

# USDA FoodData Central API (nutritional reference data)
# Get your key at: https://fdc.nal.usda.gov/api-guide
USDA_API_KEY=...

# Yelp Fusion API (reviews, business data)
YELP_API_KEY=...
